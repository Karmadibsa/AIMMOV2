# ── LLM (Google AI Studio) ────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMMA_MODEL=gemma-4-27b-it

# ── Base de données annonces (Supabase) ───────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ── URLs (déploiement cloud) ──────────────────────────────────────────────────
# Backend Render/Koyeb → à renseigner dans les secrets Streamlit Cloud
BACKEND_URL=https://your-backend.onrender.com
# Restreindre les origines CORS une fois le domaine Streamlit Cloud connu
ALLOWED_ORIGINS=*

# ── Alertes email (optionnel) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=

# ── Alertes Slack (optionnel) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
